generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id     Int    @id @default(autoincrement())
  name   String @unique @default("patient")
  prefix String
  users  User[]

  @@map("roles")
}

model User {
  id                String             @id @default(uuid())
  username          String             @unique
  email             String             @unique
  citizen_id        String?            @unique @map("citizen_id")
  password          String
  avatar            String?            @default("https://cdn.pixabay.com/photo/2016/08/08/09/17/avatar-1577909_960_720.png")
  birthday          DateTime?
  gender            UserGender         @default(male)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  phone             String?
  addressId         String?            @unique @map("address_id")
  roleId            Int                @map("role_id")
  authentication    Authentication?
  name              Name?
  patient           Patient?
  sessions          Session[]
  staff             Staff?
  address           Address?           @relation(fields: [addressId], references: [id])
  role              Role               @relation(fields: [roleId], references: [id])
  verificationCodes VerificationCode[]
  articles          HealthArticle[]    @relation("UserArticles")
  conversations     Conversation[]
  notification      Notification[]
  contact           Contact[]
  appointment       Appointment[]
  assignedArticles  HealthArticle[]    @relation("UserAssignee")
  visitServices     VisitService[]
  prescriptions     Prescription[]
  invoices          Invoice[]

  @@index([roleId])
  @@index([createdAt])
  @@map("users")
}

model Authentication {
  userId     String    @id @map("user_id")
  googleId   String?   @unique @map("google_id")
  facebookId String?   @unique @map("facebook_id")
  lastLogin  DateTime? @map("last_login")
  createdAt  DateTime  @default(now()) @map("created_at")
  isVerified Boolean   @default(false) @map("is_verified")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVerified])
  @@index([lastLogin])
  @@map("authentications")
}

model VerificationCode {
  id           String    @id @default(uuid())
  userId       String?
  email        String?
  code         String
  type         String
  resendCount  Int       @default(0) @map("resend_count")
  lastResendAt DateTime? @map("last_resend_at")
  channel      String    @default("EMAIL")
  expiresAt    DateTime
  used         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([code])
  @@index([used])
  @@index([expiresAt])
  @@map("verification_codes")
}

model Name {
  firstName String @map("first_name")
  lastName  String @map("last_name")
  userId    String @id @map("user_id")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("names")
}

model Address {
  id        String    @id @default(uuid())
  detail    String
  ward      String
  district  String?
  city      String
  country   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hospital  Hospital?
  user      User?

  @@map("addresses")
}

model Staff {
  userId           String            @id @map("user_id")
  staffId          String            @unique @default(cuid()) @map("staff_id")
  departmentId     Int               @map("department_id")
  position         String
  joinTime         DateTime          @map("join_time")
  leaveTime        DateTime?         @map("leave_time")
  department       Department        @relation("StaffDepartment", fields: [departmentId], references: [id])
  headOfDepartment Department?       @relation("DepartmentHead")
  deputyOf         DepartmentDeputy?
  doctor           Doctor?
  manager          Manager?
  schedules        Schedule[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactReplies   Contact[]         @relation("ContactReplyStaff")

  @@index([departmentId])
  @@index([position])
  @@map("staffs")
}

model Doctor {
  userId          String          @id @map("user_id")
  specialization  String
  licenseNumber   String?         @unique @map("license_number")
  experienceYears Int             @map("experience_years")
  level           String
  appointments    Appointment[]
  staff           Staff           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  medicalRecords  MedicalRecord[]
  doctorServices  DoctorService[]
  visits          Visit[]

  @@index([specialization])
  @@index([level])
  @@map("doctors")
}

model Manager {
  userId String @id @map("user_id")
  staff  Staff  @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("managers")
}

enum DepartmentType {
  clinical
  paraclinical
  administrative
}

model Department {
  id              Int                @id @default(autoincrement())
  name            String             @unique
  description     String
  code            String             @unique
  phone           String?
  thumbnail       String?
  images          String[]
  type            DepartmentType
  headId          String?            @unique @map("head_id")
  roomId          String?            @unique @map("room_id")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  staffs          Staff[]            @relation("StaffDepartment")
  head            Staff?             @relation("DepartmentHead", fields: [headId], references: [userId], onDelete: SetNull)
  deputies        DepartmentDeputy[]
  medicalServices MedicalService[]
  room            Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)
  schedules       Schedule[]
  appointments    Appointment[]

  @@index([type])
  @@map("departments")
}

model DepartmentDeputy {
  id           Int        @id @default(autoincrement())
  departmentId Int        @map("department_id")
  userId       String     @unique
  appointedAt  DateTime   @default(now()) @map("appointed_at")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  staff        Staff      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@map("department_deputies")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Patient {
  userId            String             @id @map("user_id")
  patientId         String             @unique @default(cuid()) @map("patient_id")
  appointments      Appointment[]
  healthInsurances  HealthInsurance[]
  invoices          Invoice[]
  healthInfo        HealthInformation?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ehr               EHR?
  emergencyContacts EmergencyContact[]
  visits            Visit[]

  @@map("patients")
}

model EmergencyContact {
  id           String   @id @default(uuid())
  patientId    String   @map("patient_id")
  fullName     String   @map("full_name")
  relationship String   @map("relationship")
  phone        String
  email        String?
  patient      Patient  @relation(fields: [patientId], references: [userId], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([patientId])
  @@map("emergency_contacts")
}

model HealthInsurance {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  type             String
  insuranceId      String    @unique @map("insurance_id")
  startAt          DateTime  @map("start_at")
  endAt            DateTime  @map("end_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  initial_kcb_code String?   @map("initial_kcb_code")
  initial_kcb_name String?   @map("initial_kcb_name")
  level_of_benefit Float?    @map("level_of_benefit")
  province_code    String?   @map("province_code")
  user             Patient   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  invoices         Invoice[] // Các hóa đơn sử dụng thẻ bảo hiểm này

  @@index([userId])
  @@index([endAt])
  @@map("health_insurances")
}

model EHR {
  id        String   @id @default(uuid())
  patientId String?  @unique @map("patient_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  patient   Patient? @relation(fields: [patientId], references: [userId], onDelete: SetNull)
  visits    Visit[]

  @@index([patientId])
  @@map("ehrs")
}

enum VisitStatus {
  waiting
  in_progress
  completed
  cancelled
}

enum VisitType {
  new
  followUp
  checkUp
  consultation
  telehealth
}

model Visit {
  id               String      @id @default(uuid())
  appointmentId    String?     @map("appointment_id")
  ehrId            String      @map("ehr_id")
  doctorId         String?     @map("doctor_id")
  medicalServiceId String?     @map("medical_service_id")
  status           VisitStatus @default(in_progress)
  type             VisitType?  @default(new) @map("type")
  startTime        DateTime?   @map("start_time")
  endTime          DateTime?   @map("end_time")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  nextVisitDate    DateTime?   @map("next_visit_date")

  appointment    Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  ehr            EHR             @relation(fields: [ehrId], references: [id], onDelete: Cascade)
  doctor         Doctor?         @relation(fields: [doctorId], references: [userId], onDelete: Cascade)
  medicalRecords MedicalRecord[]
  visitServices  VisitService[]
  prescriptions  Prescription[]
  patient        Patient?        @relation(fields: [patientUserId], references: [userId])
  patientUserId  String?
  medicalService MedicalService? @relation(fields: [medicalServiceId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([ehrId])
  @@index([doctorId])
  @@index([status])
  @@index([status, startTime])
  @@index([startTime])
  @@index([createdAt])
  @@index([nextVisitDate])
  @@map("visits")
}

enum VisitServiceStatus {
  ordered
  in_progress
  done
  cancelled
}

model VisitService {
  id               String             @id @default(uuid())
  visitId          String             @map("visit_id")
  medicalServiceId String             @map("medical_service_id")
  quantity         Int                @default(1)
  price            Float
  status           VisitServiceStatus @default(ordered)
  orderedByUserId  String?            @map("ordered_by_user_id")
  orderedAt        DateTime           @default(now()) @map("ordered_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  paid             Boolean?            @default(false) @map("paid")

  visit          Visit          @relation(fields: [visitId], references: [id], onDelete: Cascade)
  medicalService MedicalService @relation(fields: [medicalServiceId], references: [id], onDelete: Cascade)
  orderedBy      User?          @relation(fields: [orderedByUserId], references: [id], onDelete: SetNull)

  @@index([visitId])
  @@index([medicalServiceId])
  @@map("visit_services")
}

model MedicalRecord {
  id         String   @id @default(uuid())
  doctorId   String?  @map("doctor_id")
  title      String
  symptoms   String
  diagnosis  String
  treatments String
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  doctor     Doctor?  @relation(fields: [doctorId], references: [userId], onDelete: SetNull)
  visit      Visit?   @relation(fields: [visitId], references: [id])
  visitId    String
  isParent   Boolean  @default(false) @map("is_parent")

  @@index([doctorId])
  @@index([visitId])
  @@index([createdAt])
  @@map("medical_records")
}

enum EntityType {
  medical_record
  prescription
  other
}

model FileAsset {
  id         String     @id @default(uuid())
  url        String
  name       String?    @map("name")
  size       Int?       @map("size")
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id")
  fileType   String?    @map("file_type")
  mimeType   String?    @map("mime_type")
  isPrivate  Boolean    @default(false) @map("is_private")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@map("file_assets")
}

enum AppointmentType {
  new
  followUp
  checkUp
  consultation
  telehealth
}

enum SourceAppointment {
  online
  walkIn
}

model Appointment {
  id               String            @id @default(uuid())
  patientId        String            @map("patient_id")
  doctorId         String?           @map("doctor_id")
  scheduleId       String?           @map("schedule_id")
  medicalServiceId String?           @map("medical_service_id")
  bookedByUserId   String?           @map("booked_by_user_id")
  departmentId     Int?              @map("department_id")
  type             AppointmentType   @default(new)
  startTime        DateTime          @map("start_time")
  endTime          DateTime?         @map("end_time")
  reason           String            @map("reason")
  notes            String?           @map("notes")
  status           AppointmentStatus @default(pending)
  source           SourceAppointment @default(online)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  doctor           Doctor?           @relation(fields: [doctorId], references: [userId], onDelete: Cascade)
  patient          Patient           @relation(fields: [patientId], references: [userId], onDelete: Cascade)
  schedule         Schedule?         @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  medicalService   MedicalService?   @relation(fields: [medicalServiceId], references: [id], onDelete: SetNull)
  bookedBy         User?             @relation(fields: [bookedByUserId], references: [id], onDelete: SetNull)
  reasonCancel     String?           @map("reason_cancel")
  visits           Visit[]
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduleId])
  @@index([medicalServiceId])
  @@index([status])
  @@index([startTime])
  @@index([createdAt])
  @@index([bookedByUserId])
  @@map("appointments")
}

model Hospital {
  id        String     @id @default(uuid())
  name      String
  addressId String?    @unique @map("address_id")
  phone     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  buildings Building[]
  address   Address?   @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([name])
  @@map("hospitals")
}

model Building {
  id         String   @id @default(uuid())
  hospitalId String   @map("hospital_id")
  name       String
  floorCount Int      @map("floor_count")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  rooms      Room[]

  @@index([hospitalId])
  @@map("buildings")
}

enum RoomStatus {
  not_used
  used
  maintenance
}

model Room {
  id              String           @id @default(uuid())
  buildingId      String           @map("building_id")
  name            String
  number_room     Int              @map("number_room")
  floor           Int
  type            RoomType
  status          RoomStatus       @default(not_used)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  building        Building         @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  schedules       Schedule[]
  department      Department?
  medicalServices MedicalService[]

  @@index([buildingId])
  @@index([type])
  @@index([floor])
  @@map("rooms")
}

enum ScheduleType {
  appointment
  work
  surgery
  duty
  admin
  off
}

enum ScheduleStatus {
  pending
  confirmed
  cancelled
  completed
}

model Schedule {
  id           String         @id @default(uuid())
  staffId      String         @map("staff_id")
  departmentId Int            @map("department_id")
  type         ScheduleType   @default(work)
  roomId       String         @map("room_id")
  date         DateTime       @map("date")
  status       ScheduleStatus @default(confirmed)
  maxSlot      Int?           @map("max_slot")
  startTime    DateTime       @map("start_time")
  endTime      DateTime       @map("end_time")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  department   Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  room         Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  staff        Staff          @relation(fields: [staffId], references: [userId], onDelete: Cascade)
  appointments Appointment[]

  @@index([staffId])
  @@index([roomId])
  @@index([date])
  @@index([startTime])
  @@map("schedules")
}

model HealthInformation {
  id                      String   @id @default(uuid())
  patientId               String   @unique @map("patient_id")
  weight                  Float?   @map("weight")
  height                  Float?   @map("height")
  bloodType               String?  @map("blood_type")
  has_high_blood_pressure Boolean? @default(false) @map("has_high_blood_pressure")
  has_diabetes            Boolean? @default(false) @map("has_diabetes")
  has_allergies           Boolean? @default(false) @map("has_allergies")
  has_cancer              Boolean? @default(false) @map("has_cancer")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  patient                 Patient  @relation(fields: [patientId], references: [userId], onDelete: Cascade)

  @@map("health_informations")
}

model MedicalService {
  id                          String          @id @default(uuid())
  images                      String[]        @map("image_url")
  roomId                      String?         @map("room_id")
  name                        String
  description                 String?
  price                       Float
  unit                        String?         @map("unit")
  durationMinutes             Float           @map("duration_minutes")
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  isActive                    Boolean         @default(true) @map("is_active")
  percentApplyHealthInsurance Float           @default(0) @map("percent_apply_health_insurance")
  departmentId                Int             @map("department_id")
  department                  Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  room                        Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  doctorServices              DoctorService[]
  appointments                Appointment[]
  visitServices               VisitService[]
  visits                      Visit[]

  @@index([departmentId])
  @@index([isActive])
  @@index([name])
  @@index([roomId])
  @@map("medical_services")
}

model DoctorService {
  doctorId         String         @map("doctor_id")
  medicalServiceId String         @map("medical_service_id")
  price            Float
  durationMinutes  Float          @map("duration_minutes")
  isActive         Boolean        @default(true) @map("is_active")
  doctor           Doctor         @relation(fields: [doctorId], references: [userId], onDelete: Cascade)
  medicalService   MedicalService @relation(fields: [medicalServiceId], references: [id], onDelete: Cascade)

  @@id([doctorId, medicalServiceId])
  @@index([medicalServiceId])
  @@map("doctor_services")
}

model Invoice {
  id                String           @id @default(uuid())
  patientId         String           @map("patient_id")
  healthInsuranceId String?          @map("health_insurance_id")
  status            InvoiceStatus    @default(pending)
  // Financial breakdown
  discountAmount    Float            @default(0) @map("discount_amount") // Số tiền giảm giá
  discountReason    String?          @map("discount_reason") // Lý do giảm giá (nếu có)
  taxAmount         Float            @default(0) @map("tax_amount") // Số tiền thuế
  totalAmount       Float            @default(0) @map("total_amount") // Tổng
  // Metadata
  notes             String?          @db.Text // Ghi chú cho hóa đơn
  issuedByUserId    String?          @map("issued_by_user_id") // ID của nhân viên tạo hóa đơn
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  patient           Patient          @relation(fields: [patientId], references: [userId], onDelete: Cascade)
  healthInsurance   HealthInsurance? @relation(fields: [healthInsuranceId], references: [id])
  payment           Payment?
  invoiceItems      InvoiceItem[]
  issuedBy          User?            @relation(fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([healthInsuranceId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

enum InvoiceItemType {
  service
  medicine
}

model InvoiceItem {
  id          String          @id @default(uuid())
  invoiceId   String          @map("invoice_id")
  item_type   InvoiceItemType @map("item_type")
  refId       String          @map("ref_id") // ID tham chiếu đến dịch vụ y tế hoặc thuốc
  name        String
  quantity    Int             @default(1)
  unitPrice   Float           @map("unit_price")
  description String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(uuid())
  invoiceId     String        @unique @map("invoice_id")
  userName      String?       @map("user_name")
  paymentMethod PaymentMethod @default(cash_on_delivery) @map("payment_method")
  amount        Float         @default(0)
  status        PaymentStatus @default(pending)
  message       String?       @db.Text
  metadata      Json?         @map("metadata")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([paymentMethod])
  @@index([createdAt])
  @@map("payments")
}

enum MedicineStatus {
  available
  out_of_stock
}

model Medicine {
  id                String          @id @default(uuid())
  name              String //Tên thuốc
  genericName       String          @map("generic_name") //Tên hoạt chất
  brandName         String          @map("brand_name") //Tên thương hiệu
  description       String          @db.Text //Mô tả
  category          String // Nhóm thuốc (giảm đau, kháng sinh...)
  form              String //Hình thức bào chế (viên nang, viên nén, viên bột...)
  dosage            String //Liều lượng
  unit              String //Đơn vị tính (viên, lọ, ống...)
  price             Float //Giá bán lẻ
  manufacturer      String // Nhà sản xuất
  country           String // Quốc gia sản xuất
  sideEffects       String[]        @map("side_effects") // Tác dụng phụ
  interactions      String[] // Tương tác với các thuốc khác
  indications       String[] // Chỉ định sử dụng
  contraindications String[] // Trường hợp không sử dụng
  storageConditions String?         @map("storage_conditions") // Điều kiện bảo quản
  stock             Int // Số lượng tồn kho
  status            MedicineStatus? @default(available) // Trạng thái của thuốc (hết hàng, còn hàng)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  medicineUsages    MedicineUsage[]

  @@index([name])
  @@index([category])
  @@index([manufacturer])
  @@map("medicines")
}

model Prescription {
  id              String          @id @default(uuid())
  visitId         String          @map("visit_id")
  createdByUserId String?         @map("created_by_user_id")
  paid            Boolean         @default(false) @map("paid")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  medicineUsages  MedicineUsage[]
  visit           Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([visitId])
  @@index([paid])
  @@index([createdAt])
  @@map("prescriptions")
}

model MedicineUsage {
  id             String       @id @default(uuid())
  prescriptionId String       @map("prescription_id")
  medicineId     String?      @map("medicine_id")
  quantity       Int          @default(1)
  price          Float
  drugName       String?      @map("drug_name")
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isPurchased    Boolean      @default(true) @map("is_purchased")
  medicine       Medicine?    @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@index([medicineId])
  @@map("medicine_usages")
}

model Counter {
  id    String @id @default(uuid())
  value BigInt @default(0)

  @@map("counters")
}

enum UserRole {
  patient
  doctor
  admin
  pharmacist
  accountant
}

enum UserGender {
  male
  female
  other
}

enum AppointmentStatus {
  pending
  confirmed
  checked_in
  cancelled
  completed
  rejected
  no_show
  in_progress
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum PaymentMethod {
  cash_on_delivery
  credit_card
  bank_transfer
}

enum RoomType {
  examination
  emergency
  operating
  intensive_care
  recovery
  patient_ward
  isolation
  maternity
  pediatric
  laboratory
  radiology
  pharmacy
  consultation
  waiting
  staff
  office
}

enum BedStatus {
  available
  occupied
  maintenance
}

enum InvoiceStatus {
  pending
  paid
  cancelled
}

enum ArticleStatus {
  draft
  pending_review
  published
  rejected
  reedited
}

model Category {
  id          String          @id @default(uuid())
  name        String          @unique
  slug        String          @unique
  parentId    String?         @map("parent_id")
  parent      Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]      @relation("CategoryHierarchy")
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  articles    HealthArticle[]

  @@index([parentId])
  @@map("categories")
}

model HealthArticle {
  id           String        @id @default(uuid())
  title        String
  content      String        @db.Text
  summary      String?
  slug         String        @unique
  imageUrl     String?       @map("image_url")
  images       String[]      @map("images")
  viewCount    Int           @default(0) @map("view_count")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  publishedAt  DateTime?     @map("published_at")
  authorId     String        @map("author_id")
  categoryId   String        @map("category_id")
  author       User          @relation("UserArticles", fields: [authorId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status       ArticleStatus @default(draft)
  featured     Boolean       @default(false) // đánh dấu bài viết nổi bật để hiển thị trên trang chủ
  extras       Json?         @map("extras")
  toc          Json?         @map("toc")
  assigneeId   String?       @map("assignee_id") // người được giao nhiệm vụ chỉnh sửa lại bài viết
  assignee     User?         @relation("UserAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reasonReject String?       @map("reason_reject") // lý do từ chối duyệt bài viết

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([assigneeId])
  @@index([publishedAt])
  @@index([createdAt])
  @@map("health_articles")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  title     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId])
  @@index([createdAt])
  @@map("conversations")
}

enum MessageSender {
  user
  bot
}

model Message {
  id             String        @id @default(uuid())
  conversationId String        @map("conversation_id")
  content        String
  sender         MessageSender @default(user)
  useFul         Boolean?
  star           Float?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@index([sender])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String?
  content   String
  type      String?  @map("type")
  isRead    Boolean  @default(false) @map("is_read")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}

model Contact {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  fullname    String
  email       String
  phone       String?
  subject     String?
  content     String
  isRead      Boolean   @default(false) @map("is_read")
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userIdReply String?   @map("staff_id_reply")
  userReply   Staff?    @relation("ContactReplyStaff", fields: [userIdReply], references: [userId], onDelete: SetNull)
  reply       String?
  replyAt     DateTime? @map("reply_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("contacts")
}
