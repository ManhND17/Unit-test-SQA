{
    "compilerOptions": {
        "types": [
            "node",
            "expect-webdriverio",
            "mocha",
            "@wdio/globals/types",
            "@wdio/mocha-framework",
            "webdriverio",
            "@wdio/types"
        ],
        "target": "es2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": [
            "es2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "*": [
                "./node_modules/*"
            ]
        }
    },
    "include": [
        "test/**/*.ts",
        "wdio.conf.ts"
    ]
}